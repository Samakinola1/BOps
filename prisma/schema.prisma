// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  name               String?
  role               String    @default("ADMIN") // ADMIN, USER etc.
  emailVerified      Boolean   @default(false)
  verificationToken  String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  // Relations
  businessId         String?
  business           Business? @relation(fields: [businessId], references: [id])
  businessUser       BusinessUser?
  activityLogs       ActivityLog[]
}

model Business {
  id                  String    @id @default(uuid())
  name                String
  logoUrl             String?
  address             String?
  taxNumber           String?
  currency            String    @default("USD")
  invoicePrefix       String    @default("INV-")
  invoicePadding      Int       @default(4)
  nextInvoiceNumber   Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  users               User[]
  customers           Customer[]
  products            Product[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  invoices            Invoice[]
  quotations          Quotation[]
  customRoles         CustomRole[]
  businessUsers       BusinessUser[]
  activityLogs        ActivityLog[]
}

model Customer {
  id           String    @id @default(uuid())
  name         String
  businessName String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  quotations   Quotation[]
}

model Product {
  id           String    @id @default(uuid())
  sku          String    @unique
  name         String
  description  String?
  costPrice    Float
  sellingPrice Float
  quantity     Float     @default(0)
  unit         String    @default("pcs")
  reorderLevel Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  businessId   String
  business     Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  quotationItems QuotationItem[]
  transactions InventoryTransaction[]
}

model Invoice {
  id             String    @id @default(uuid())
  invoiceNumber  String    // e.g. "INV-0001"
  issueDate      DateTime
  dueDate        DateTime
  status         String    @default("Draft") // Draft, Sent, Paid, Partially Paid, Overdue, Cancelled
  taxRate        Float     @default(0)      // Percentage
  taxAmount      Float     @default(0)
  discountRate   Float     @default(0)      // Percentage
  discountAmount Float     @default(0)
  totalAmount    Float
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items          InvoiceItem[]
  payments       Payment[]
}

model InvoiceItem {
  id           String   @id @default(uuid())
  quantity     Float
  unitPrice    Float
  taxRate      Float    @default(0)
  discountRate Float    @default(0)
  totalAmount  Float
  
  // Relations
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Quotation {
  id             String    @id @default(uuid())
  quoteNumber    String    // e.g. "QT-0001"
  issueDate      DateTime
  expiryDate     DateTime
  status         String    @default("Draft") // Draft, Sent, Accepted, Rejected, Expired
  taxRate        Float     @default(0)
  taxAmount      Float     @default(0)
  discountRate   Float     @default(0)
  discountAmount Float     @default(0)
  totalAmount    Float
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items          QuotationItem[]
}

model QuotationItem {
  id           String        @id @default(uuid())
  description  String
  quantity     Float
  unitPrice    Float
  taxRate      Float         @default(0)
  discountRate Float         @default(0)
  totalAmount  Float
  
  // Relations
  quotationId  String
  quotation    Quotation     @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Expense {
  id          String          @id @default(uuid())
  amount      Float
  vendor      String
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  date        DateTime
  receiptUrl  String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id         String    @id @default(uuid())
  name       String
  disabled   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses   Expense[]

  @@unique([businessId, name])
}

model InventoryTransaction {
  id         String   @id @default(uuid())
  type       String   // Purchase, Sale, Adjustment, Return
  quantity   Float    // Positive for addition, negative for deduction
  date       DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())

  // Relations
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  date       DateTime @default(now())
  method     String   // e.g. Cash, Bank Transfer, Card
  notes      String?
  createdAt  DateTime @default(now())

  // Relations
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CustomRole {
  id          String   @id @default(uuid())
  name        String
  permissions String   // Comma-separated permissions list, e.g. "view:invoices,manage:invoices"
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  businessUsers BusinessUser[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessUser {
  id         String      @id @default(uuid())
  businessId String
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String      @unique
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roleId     String?
  role       CustomRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  roleName   String      // "Owner", "Admin", "Manager", "Staff", or CustomRole.name

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String   // e.g. "Login", "Logout", "Invoice Created"
  details    String?  // JSON string
  createdAt  DateTime @default(now())
  
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
